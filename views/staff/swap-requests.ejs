<div class="flex h-screen overflow-hidden">
  <%- include('../partials/staffSidebar', { activePage: 'swap-requests' }) %>

  <!-- Main Content -->
  <main class="flex-1 overflow-y-auto">
    <!-- Header -->
    <header class="sticky top-0 z-10 bg-white/80 dark:bg-slate-900/80 backdrop-blur-md border-b border-slate-200 dark:border-slate-800 px-8 py-4 flex items-center justify-between">
      <div>
        <h2 class="text-2xl font-black tracking-tight">Shift Swap Requests</h2>
        <p class="text-slate-500 text-sm">Request to swap shifts with other staff</p>
      </div>
      <button onclick="document.getElementById('createSwapModal').showModal()" class="bg-primary text-white px-4 py-2 rounded-lg text-sm font-semibold flex items-center gap-2">
        <span class="material-symbols-outlined text-[20px]">swap_horiz</span>
        Request Swap
      </button>
    </header>

    <div class="p-8 max-w-5xl mx-auto space-y-6">
      <!-- Flash Messages -->
      <% if (typeof success !== 'undefined' && success) { %>
        <div class="p-4 bg-emerald-50 dark:bg-emerald-900/20 border border-emerald-200 dark:border-emerald-800 rounded-lg flex items-center gap-3">
          <span class="material-symbols-outlined text-emerald-600 dark:text-emerald-400">check_circle</span>
          <p class="text-sm text-emerald-700 dark:text-emerald-300"><%= success %></p>
        </div>
      <% } %>
      <% if (typeof error !== 'undefined' && error) { %>
        <div class="p-4 bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-lg flex items-center gap-3">
          <span class="material-symbols-outlined text-red-600 dark:text-red-400">error</span>
          <p class="text-sm text-red-700 dark:text-red-300"><%= error %></p>
        </div>
      <% } %>

      <!-- My Swap Requests -->
      <div class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 overflow-hidden">
        <div class="p-6 border-b border-slate-200 dark:border-slate-800">
          <h3 class="font-bold text-lg">My Swap Requests</h3>
        </div>
        <div class="divide-y divide-slate-100 dark:divide-slate-800">
          <% if (swapRequests && swapRequests.length > 0) { %>
            <% swapRequests.forEach(function(req) { %>
              <div class="p-6">
                <div class="flex items-start justify-between">
                  <div class="flex-1">
                    <div class="flex items-center gap-3 mb-2">
                      <span class="font-bold text-slate-900 dark:text-white">
                        <%= req.targetShift ? req.targetShift.title || 'Shift #' + req.targetShift.id : 'Unknown Shift' %>
                      </span>
                      <% if (req.status === 'PENDING') { %>
                        <span class="px-2 py-1 bg-amber-100 text-amber-700 text-xs font-bold rounded">Pending</span>
                      <% } else if (req.status === 'APPROVED') { %>
                        <span class="px-2 py-1 bg-emerald-100 text-emerald-700 text-xs font-bold rounded">Approved</span>
                      <% } else if (req.status === 'REJECTED') { %>
                        <span class="px-2 py-1 bg-red-100 text-red-700 text-xs font-bold rounded">Rejected</span>
                      <% } %>
                    </div>
                    <p class="text-sm text-slate-500">
                      <%= req.targetShift ? new Date(req.targetShift.shiftDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : '' %>
                      <%= req.targetShift && req.targetShift.scheduledStart ? ' - ' + req.targetShift.scheduledStart : '' %>
                    </p>
                    <% if (req.reason) { %>
                      <p class="text-sm text-slate-600 dark:text-slate-400 mt-2"><%= req.reason %></p>
                    <% } %>
                    <div class="mt-3 flex flex-wrap gap-2 text-xs">
                      <span class="px-2 py-1 rounded-full bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-300">
                        Target response:
                        <% if (req.targetAccepted === true) { %>Accepted<% } else if (req.targetAccepted === false) { %>Rejected<% } else { %>Pending<% } %>
                      </span>
                      <% if (req.approvedAt) { %>
                        <span class="px-2 py-1 rounded-full bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-300">
                          Reviewed <%= new Date(req.approvedAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) %>
                        </span>
                      <% } %>
                    </div>
                    <% if (req.managerComment) { %>
                      <div class="mt-3 p-3 bg-slate-50 dark:bg-slate-800 rounded-lg">
                        <p class="text-xs font-bold text-slate-500 mb-1">Manager Comment:</p>
                        <p class="text-sm text-slate-700 dark:text-slate-300"><%= req.managerComment %></p>
                      </div>
                    <% } %>
                    <% if (req.targetRejectionReason) { %>
                      <div class="mt-3 p-3 bg-red-50 dark:bg-red-900/20 rounded-lg">
                        <p class="text-xs font-bold text-red-500 mb-1">Target Rejection:</p>
                        <p class="text-sm text-red-700 dark:text-red-300"><%= req.targetRejectionReason %></p>
                      </div>
                    <% } %>
                  </div>
                  <div class="text-xs text-slate-400">
                    <%= new Date(req.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) %>
                  </div>
                </div>
              </div>
            <% }); %>
          <% } else { %>
            <div class="p-8 text-center text-slate-500">
              <span class="material-symbols-outlined text-4xl mb-2">swap_horiz</span>
              <p>No swap requests yet</p>
            </div>
          <% } %>
        </div>
      </div>
    </div>
  </main>
</div>

<!-- Create Swap Modal -->
<dialog id="createSwapModal" class="modal p-6 rounded-xl border border-slate-200 dark:border-slate-700 backdrop:bg-slate-900/50 w-full max-w-lg">
  <div class="space-y-4">
    <div class="flex items-center justify-between">
      <h3 class="text-lg font-bold text-slate-900 dark:text-white">Request Shift Swap</h3>
      <button onclick="document.getElementById('createSwapModal').close()" class="p-1 hover:bg-slate-100 dark:hover:bg-slate-800 rounded">
        <span class="material-symbols-outlined text-slate-500">close</span>
      </button>
    </div>
    <form action="/staff/swap-requests" method="POST">
      <div class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">Shift to Swap</label>
          <select name="targetShiftId" required class="w-full px-4 py-2 rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-slate-900 dark:text-white">
            <option value="">Select a shift...</option>
            <% if (myShifts && myShifts.length > 0) { %>
              <optgroup label="My Assigned Shifts">
                <% myShifts.forEach(function(assignment) { %>
                  <% if (assignment.Shift) { %>
                    <option value="<%= assignment.Shift.id %>">
                      <%= new Date(assignment.Shift.shiftDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) %>
                      - <%= assignment.Shift.title || assignment.Shift.shiftType %>
                      (<%= assignment.Shift.scheduledStart || 'TBD' %>)
                    </option>
                  <% } %>
                <% }); %>
              </optgroup>
            <% } %>
            <% if (allShifts && allShifts.length > 0) { %>
              <optgroup label="All Available Shifts">
                <% allShifts.forEach(function(shift) { %>
                  <option value="<%= shift.id %>">
                    <%= new Date(shift.shiftDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %>
                    - <%= shift.title || shift.shiftType %>
                    (<%= shift.scheduledStart || 'TBD' %>)
                  </option>
                <% }); %>
              </optgroup>
            <% } %>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">Swap With Staff <span class="text-red-500">*</span></label>
          <select name="targetUserId" required class="w-full px-4 py-2 rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-slate-900 dark:text-white">
            <option value="">Select a staff member...</option>
            <% if (staffMembers && staffMembers.length > 0) { %>
              <% staffMembers.forEach(function(staff) { %>
                <option value="<%= staff.id %>"><%= staff.fullName %></option>
              <% }); %>
            <% } %>
          </select>
          <p class="text-xs text-slate-500 mt-1">Select the staff member you want to swap with</p>
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">Reason</label>
          <textarea name="reason" rows="3" placeholder="Why do you need to swap?" class="w-full px-4 py-2 rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-slate-900 dark:text-white"></textarea>
        </div>
      </div>
      <div class="flex gap-3 mt-6">
        <button type="button" onclick="document.getElementById('createSwapModal').close()" class="flex-1 px-4 py-2 bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 rounded-lg hover:bg-slate-200 dark:hover:bg-slate-700 transition-colors">Cancel</button>
        <button type="submit" class="flex-1 px-4 py-2 bg-primary text-white rounded-lg hover:bg-primary/90 transition-colors">Submit Request</button>
      </div>
    </form>
  </div>
</dialog>
