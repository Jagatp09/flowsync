<div class="flex h-screen overflow-hidden">
  <%- include('../partials/staffSidebar', { activePage: 'settings' }) %>

  <!-- Main Content -->
  <main class="flex-1 overflow-y-auto">
    <!-- Header -->
    <header class="sticky top-0 z-10 bg-white/80 dark:bg-slate-900/80 backdrop-blur-md border-b border-slate-200 dark:border-slate-800 px-8 py-4 flex items-center justify-between">
      <div class="flex items-center gap-4">
        <h2 class="text-xl font-bold">Settings</h2>
      </div>
      <div class="flex items-center gap-4">
        <button class="size-10 flex items-center justify-center rounded-xl bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-300">
          <span class="material-symbols-outlined">notifications</span>
        </button>
      </div>
    </header>

    <div class="p-8 max-w-4xl mx-auto space-y-6">
      <div>
        <h1 class="text-3xl font-black text-slate-900 dark:text-white">Settings</h1>
        <p class="text-slate-500 mt-1">Account controls, shift access, and support details for your current workspace.</p>
      </div>

      <div class="grid grid-cols-1 xl:grid-cols-2 gap-6">
        <div class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 p-6 shadow-sm">
          <h4 class="text-lg font-bold text-slate-900 dark:text-white mb-4">Account</h4>
          <div class="space-y-4">
            <div>
              <p class="text-sm font-medium text-slate-700 dark:text-slate-300">Full Name</p>
              <p class="mt-1 text-slate-900 dark:text-white"><%= user ? user.fullName : '' %></p>
            </div>
            <div>
              <p class="text-sm font-medium text-slate-700 dark:text-slate-300">Email Address</p>
              <p class="mt-1 text-slate-900 dark:text-white"><%= user ? user.email : '' %></p>
            </div>
            <div>
              <p class="text-sm font-medium text-slate-700 dark:text-slate-300">Role</p>
              <p class="mt-1 text-slate-900 dark:text-white">Staff</p>
            </div>
            <p class="text-xs text-slate-500">Profile details are managed centrally so staff records stay consistent across scheduling, checklists, and reports.</p>
          </div>
        </div>

        <div class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 p-6 shadow-sm">
          <h4 class="text-lg font-bold text-slate-900 dark:text-white mb-4">Shift Access</h4>
          <div class="space-y-4">
            <div>
              <p class="text-sm font-medium text-slate-700 dark:text-slate-300">Checklist Access Today</p>
              <div class="flex flex-wrap gap-2 mt-2">
                <% if (assignedShiftTypes && assignedShiftTypes.length > 0) { %>
                  <% assignedShiftTypes.forEach(function(shiftType) { %>
                    <span class="px-3 py-1 bg-primary/10 text-primary text-xs font-bold rounded-full"><%= shiftType %></span>
                  <% }); %>
                <% } else { %>
                  <span class="text-sm text-slate-500">No shift-specific checklist access right now.</span>
                <% } %>
              </div>
            </div>
            <div>
              <p class="text-sm font-medium text-slate-700 dark:text-slate-300">Next Scheduled Shift</p>
              <% if (nextShift) { %>
                <p class="mt-1 text-slate-900 dark:text-white"><%= nextShift.title || nextShift.shiftType %></p>
                <p class="text-sm text-slate-500">
                  <%= new Date(nextShift.shiftDate).toLocaleDateString('en-US', { weekday: 'long', month: 'short', day: 'numeric' }) %>
                  <% if (nextShift.scheduledStart && nextShift.scheduledEnd) { %>
                    • <%= nextShift.scheduledStart %> - <%= nextShift.scheduledEnd %>
                  <% } %>
                </p>
              <% } else { %>
                <p class="mt-1 text-sm text-slate-500">No upcoming shift is currently assigned.</p>
              <% } %>
            </div>
          </div>
        </div>
      </div>

      <div class="grid grid-cols-1 xl:grid-cols-2 gap-6">
        <div class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 p-6 shadow-sm">
          <h4 class="text-lg font-bold text-slate-900 dark:text-white mb-4">Security</h4>
          <div class="space-y-3 text-sm text-slate-600 dark:text-slate-300">
            <p>Your session uses secure server-side storage and protected form submissions.</p>
            <p>Use the logout button in the sidebar when you finish a shift or leave a shared workstation.</p>
            <p>For password or account changes, contact your manager so the change is reflected across scheduling and approvals.</p>
          </div>
        </div>

        <div class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 p-6 shadow-sm">
          <h4 class="text-lg font-bold text-slate-900 dark:text-white mb-4">Support</h4>
          <% if (managerContact) { %>
            <p class="text-slate-900 dark:text-white font-medium"><%= managerContact.fullName %></p>
            <p class="text-sm text-slate-500 mt-1"><%= managerContact.email %></p>
          <% } else { %>
            <p class="text-sm text-slate-500">No manager contact is currently configured.</p>
          <% } %>
          <p class="text-sm text-slate-500 mt-4">Need schedule changes, profile updates, or help with checklist access? Reach out to your store manager.</p>
        </div>
      </div>
    </div>
  </main>
</div>
